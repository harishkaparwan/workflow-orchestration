{
  "name": "n8n-worker",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/n8n-worker",
  "targets": {
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash apps/n8n-worker/scripts/start.sh"
      }
    },
    "healthcheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash apps/n8n-worker/scripts/healthcheck.sh"
      }
    },
    "export-workflows": {
      "executor": "nx:run-commands",
      "options": {
        "command": "export $(grep -v '^#' apps/n8n-worker/config/default.env | xargs) && n8n export:workflow --backup --output=packages/n8n-workflows/workflows/"
      }
    }
  }
}
