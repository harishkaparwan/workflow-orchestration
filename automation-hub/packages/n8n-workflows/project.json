{
  "name": "n8n-workflows",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/n8n-workflows",
  "targets": {
    "import": {
      "executor": "nx:run-commands",
      "options": {
        "command": "export $(grep -v '^#' apps/n8n-worker/config/default.env | xargs) && n8n import:workflow --input=packages/n8n-workflows/workflows/"
      }
    }
  }
}
